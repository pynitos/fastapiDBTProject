{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
       
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Tg Bot",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_bot.py",
            "console": "integratedTerminal",
            "env": {
                "LOG_LEVEL": "DEBUG",
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${command:python.interpreterPath}",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "fastapi",
            "args": [
                "run",
                "./src/diary_ms/main/web.py",
            ],
            "env": {
                "LOG_LEVEL": "DEBUG",
                "PYTHONPATH": "${workspaceFolder}/src"
            },
        },
        {
            "name": "Scheduler",
            "type": "debugpy",
            "request": "launch",
            "module": "taskiq",
            "args": [
                "scheduler",
                "src.diary_ms.infrastructure.tasks.brokers.broker:scheduler",
            ],
            "env": {
                "LOG_LEVEL": "DEBUG",
                "PYTHONPATH": "${workspaceFolder}/src"
            },
        },
        {
            "name": "Taskiq",
            "type": "debugpy",
            "request": "launch",
            "module": "taskiq",
            "args": [
                "worker",
                "src.diary_ms.infrastructure.tasks.brokers.broker:task_broker",
            ],
            "env": {
                "LOG_LEVEL": "DEBUG",
                "PYTHONPATH": "${workspaceFolder}/src"
            },
        }
    ]
}